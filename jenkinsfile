pipeline {
    agent any

    stages {
        stage('Pull') {
            steps {
                git branch: 'main', url: 'https://github.com/SanjayTomar22/cdec-terraform.git'
            }
        }
        stage('Test') {
            steps {
                sh '''terraform init
                      terraform plan'''
            }
        }
        stage('Apply') {
            steps {
                sh '''terraform apply
                    '''
            }
        }
    }
}
