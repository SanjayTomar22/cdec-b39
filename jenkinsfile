pipeline {
    agent any 
    stages {
        stage ("pull-job") {
            steps {
             git branch: 'main', url: 'https://github.com/shubhamkalsait/EasyCRUD.git' 
            }
        }
        stage ("build-job") {
            steps {
               echo 'build job success' 
            }
        }
        stage ("test-job") {
            steps {
                echo 'test job success'
            }
        }
        stage ("deploy-job") {
            steps {
                echo 'deploy job success'
            }
        }
    }
}
