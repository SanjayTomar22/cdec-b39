pipeline {
    agent any 
    stages {
        stage ("pull-job") {
            steps {
             git branch: 'main', url: 'https://github.com/shubhamkalsait/EasyCRUD.git' 
            }
        }
        stage ("build-job") {
            steps {
               sh '''cd backend
                mvn clean package -DskipTests'''
            }
        }
        stage ("test-job") {
            steps {
                    withSonarQubeEnv(installationName: 'sonarqube' , credentialsId: 'sonar-cred') {
                            sh 'mvn sonar:sonar -Dsonar.projectKey=studentapp'
                        }
                }
                
        }
        stage ("deploy-job") {
            steps {
                echo 'deploy job success'
            }
        }
    }
}
