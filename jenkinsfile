pipeline {
    agent any 
    stages {
        stage ("pull-job") {
            steps {
             git branch: 'main', url: 'https://github.com/shubhamkalsait/EasyCRUD.git' 
            }
        }
        stage ("build-job") {
            steps {
               sh '''cd backend
                mvn clean package -DskipTests'''
            }
        }
        stage ("test-job") {
            steps {
                    sh '''cd backend
                        mvn sonar:sonar   -Dsonar.projectKey=studentapp   -Dsonar.projectName=\'studentapp\'   -Dsonar.host.url=http://13.232.78.253:9000   -Dsonar.token=sqp_60f615e7900fa44c965cad78fbbd3c202d73d813
                        '''
                }
                
        }
        stage ("deploy-job") {
            steps {
                echo 'deploy job success'
            }
        }
    }
}
