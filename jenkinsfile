pipeline {
    agent any 
    stages {
        stage ("pull-job") {
            steps {
             git branch: 'main', url: 'https://github.com/shubhamkalsait/EasyCRUD.git' 
            }
        }
        stage ("build-job") {
            steps {
               sh '''cd backend
                mvn clean package -DskipTests'''
            }
        }
        stage ("test-job") {
            steps {
                    withSonarQubeEnv(installationName: 'sonarqube' , credentialsId: 'sonar-cred') {
                            sh ''' 
                                cd backend
                                mvn sonar:sonar -Dsonar.projectKey=studentapp
                            '''
                        }
                }
                
        }
        stage ("Quality-Test") {
            steps {
                   timeout(10) {
                        waitForQualityGate abortPipeline: true, credentialsId: 'sonar-cred'
                    }
                }
                
        }
        stage ("deliver-job") {
            steps {
               sh 'aws s3 cp backend/target/student-registration-backend-0.0.1-SNAPSHOT.jar s3://s3-delivery-b39/easycrud.jar'
            }
        }
    }
}
